# ============================================================================
# GPU LiDAR Processing Pipeline — Makefile
# Target GPU: NVIDIA L4 (sm_89)
# CUDA Version: 12.x
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Compiler
# ─────────────────────────────────────────────────────────────────────────────
NVCC        = nvcc

# ─────────────────────────────────────────────────────────────────────────────
# Project structure
# ─────────────────────────────────────────────────────────────────────────────
SRC_DIR     = src
BIN_DIR     = bin
DATA_DIR    = data

TARGET      = lidar_pipeline

# ─────────────────────────────────────────────────────────────────────────────
# CUDA architecture flags
# Add/remove architectures depending on deployment GPU
# ─────────────────────────────────────────────────────────────────────────────
ARCH = \
	-gencode arch=compute_70,code=sm_70 \
	-gencode arch=compute_75,code=sm_75 \
	-gencode arch=compute_80,code=sm_80 \
	-gencode arch=compute_86,code=sm_86 \
	-gencode arch=compute_86,code=compute_86

# ─────────────────────────────────────────────────────────────────────────────
# Compiler flags
# ─────────────────────────────────────────────────────────────────────────────
CXXFLAGS = \
	--std=c++17 \
	-O3 \
	-lineinfo \
	-Wno-deprecated-gpu-targets \
	-I/usr/local/cuda/include

# ─────────────────────────────────────────────────────────────────────────────
# Libraries
# ─────────────────────────────────────────────────────────────────────────────
LDFLAGS = \
	-lcudart \
	-lcufft \
	-lcuda

# ─────────────────────────────────────────────────────────────────────────────
# Default target
# ─────────────────────────────────────────────────────────────────────────────
.PHONY: all build run clean dirs

all: build

# ─────────────────────────────────────────────────────────────────────────────
# Build executable
# ─────────────────────────────────────────────────────────────────────────────
build:
	$(NVCC) \
	$(SRC_DIR)/$(TARGET).cu \
	$(CXXFLAGS) \
	$(ARCH) \
	$(LDFLAGS) \
	-o $(BIN_DIR)/$(TARGET).exe

# ─────────────────────────────────────────────────────────────────────────────
# Run application
#
# Usage:
# make run
#
# OR pass argument as you see fit (example below):
# make run ARGS="100 results.csv"
# ─────────────────────────────────────────────────────────────────────────────
run: build
	./$(BIN_DIR)/$(TARGET).exe $(ARGS)

# ─────────────────────────────────────────────────────────────────────────────
# Clean build artifacts
# ─────────────────────────────────────────────────────────────────────────────
clean:
	rm -rf $(BIN_DIR)/$(TARGET).exe
	rm -rf $(OUTPUT_DIR)
	rm -f *.csv